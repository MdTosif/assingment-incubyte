{
  "buildCommand": "go mod download && cd web && npm ci && npm run build && cp -r build ../public",
  "outputDirectory": "public",
  "framework": null,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.go" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "builds": [
    { "src": "api/**/*.go", "use": "@vercel/go" }
  ]
}
